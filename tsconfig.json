{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "strict": false,
    "paths": {
      "puppeteer": ["./node_modules/puppeteer-core"]
    }
  },
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts", "tests/**/*"]
}